FRED_API_KEY=

# --- e-Stat API(Phase 2B: 日本CPI 月次)---
# 政府統計の総合窓口 e-Stat の無料 appId(https://www.e-stat.go.jp/api/)。
# 未設定だと ESTAT:CPI_JP のみ 'error' になり、他系列は取得できる。
# (統計ダッシュボード / 財務省 / 日銀 / 税関の各CSVは appId 不要)
ESTAT_APP_ID=

# --- IB(TWS / IB Gateway)接続(Phase 2: 先物・FXの一次ソース)---
# 未設定・接続不可でも yfinance フォールバックで動作する。
# 未設定時の既定: IB_HOST=127.0.0.1 / IB_PORT=7497
# ポートの目安: TWS ペーパー 7497 / TWS 本番 7496 / Gateway ペーパー 4002 / Gateway 本番 4001
IB_HOST=
IB_PORT=
# 取引システムと重複しない専用 clientId を指定する(既定: 97)
IB_CLIENT_ID=

# --- Docker 運用の補足 ---
# FETCH_AT / FETCH_ON_START / MACRO_WEB_PORT は docker-compose の変数展開で
# 解決されるため、この .env(リポジトリ直下)に書いても効かない。
# シェル環境変数(例: FETCH_AT=05:15 make docker-up)か docker/.env に書くこと。
